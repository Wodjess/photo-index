# Copy this file to .env and adjust values.
# Leave PHOTOINDEX_USER and PHOTOINDEX_PASS empty to disable upload (read-only mode).

WEB_PORT=7860

# Basic auth for upload endpoints. Leave empty to disable writes.
PHOTOINDEX_USER=
PHOTOINDEX_PASS=

# CPU threads for torch/onnxruntime. 4 is a safe default for most boxes.
OMP_NUM_THREADS=4
MKL_NUM_THREADS=4
