# Copy this file to .env and adjust values.

WEB_PORT=7860

# Single-user auth. Defaults are admin/admin if you do not set them. Set
# BOTH to empty strings to disable auth entirely (no login modal, public
# endpoints). Change the password before exposing the app to anyone else.
PHOTOINDEX_USER=admin
PHOTOINDEX_PASS=admin

# Set to 1 if you serve the app over HTTPS and want the session cookie
# marked Secure. Leave at 0 for local development over plain HTTP.
PHOTOINDEX_SESSION_SECURE=0

# Session lifetime in days. After this many days the user must log in
# again. Default is 7.
PHOTOINDEX_SESSION_TTL_DAYS=7

# Data directory override. By default the app uses
# $PHOTOINDEX_ROOT/data (or ./data/ when running from the project root).
# The Docker image sets this to /data so the ./data:/data volume mount
# lands images, OCR text, and the index at ./data/{images,ocr,index}/
# on the host. Leave the default for bare-metal.
PHOTOINDEX_DATA=/data

# CPU threads for torch/onnxruntime. 4 is a safe default for most boxes.
OMP_NUM_THREADS=4
MKL_NUM_THREADS=4
